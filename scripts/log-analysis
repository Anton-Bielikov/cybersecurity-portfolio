$logs= Get-Content "C:\\Linux_2k.log"
$errors= $logs |
Where-Object {$_ -match "Failed"} |
Select-Object @{Name="Hour"; Expression={ if ($_ -match "\d{2}:\d{2}:\d{2}") { $Matches[0].Split(':')[0] } else {"Unknown"} }} ,
@{Name="Ip"; Expression={ if ($_ -match "\d+\.\d+\.\d+\.\d+") { $Matches[0] } }} |
Where-Object { $_.Ip } |
Group-Object Hour,Ip |
Where-Object {$_.Count -gt 3} |
Sort-Object Count -Descending |
Select-Object -First 10 Count, @{Name="Hour"; Expression={($_.Name -split ", ")[0]}},
@{Name="Ip"; Expression={($_.Name -split ", ")[1]}}

Write-Output $errors | Format-Table -AutoSize

#Skrypt analizuje plik logów z systemu Linux, wyszukując wpisy zawierające słowo "Failed". Następnie:

#wyciąga z każdej linii godzinę zdarzenia oraz adres IP,

#grupuje dane według kombinacji godzina + IP,

#filtruje tylko te adresy, które wygenerowały więcej niż 3 błędy,

#sortuje wyniki malejąco i wyświetla TOP 10 najbardziej podejrzanych IP.

#Skrypt służy do szybkiej identyfikacji nietypowej aktywności, np. prób nieautoryzowanego logowania lub ataków brute‑force.
